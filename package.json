{
  "name": "ym-novel-mcp",
  "version": "0.1.0",
  "description": "A local MCP server for long-form novel project management and writing context orchestration.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "dev:http": "tsx watch src/httpIndex.ts",
    "start": "node dist/httpIndex.js",
    "start:http": "node dist/httpIndex.js",
    "start:stdio": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "release:windows:deps": "powershell -ExecutionPolicy Bypass -File scripts/package-windows-cloud-with-deps.ps1"
  },
  "keywords": [
    "mcp",
    "novel",
    "writing",
    "sqlite",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.2.1",
    "hono": "^4.12.23",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "eslint": "^9.29.0",
    "prettier": "^3.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
